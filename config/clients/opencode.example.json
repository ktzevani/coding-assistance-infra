{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "llama.cpp",
    "Ollama"
  ],
  "model": "{env:OPENCODE_MODEL}",
  "small_model": "llama.cpp/qwen3-coder-30b-32k",
  "share": "disabled",
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (local)",
      "options": {
        "baseURL": "http://host.docker.internal:8080/v1",
        "timeout": 1800000,
        "chunkTimeout": 120000
      },
      "models": {
        "qwen3-coder-30b-32k": {
          "name": "Qwen3-Coder 30B-A3B 32k",
          "limit": {
            "context": 32768,
            "output": 4096
          }
        },
        "qwen3-coder-30b-64k": {
          "name": "Qwen3-Coder 30B-A3B 64k",
          "limit": {
            "context": 65536,
            "output": 8192
          }
        },
        "qwen3-coder-30b-128k": {
          "name": "Qwen3-Coder 30B-A3B 128k",
          "limit": {
            "context": 131072,
            "output": 12288
          }
        },
        "qwen3-coder-30b-128k-planning": {
          "name": "Qwen3-Coder 30B-A3B 128k Planning",
          "limit": {
            "context": 131072,
            "output": 16384
          }
        },
        "qwen3-coder-30b-256k": {
          "name": "Qwen3-Coder 30B-A3B 256k",
          "limit": {
            "context": 262144,
            "output": 16384
          }
        },
        "qwen3-6-35b-a3b-64k": {
          "name": "Qwen3.6 35B-A3B 64k",
          "limit": {
            "context": 65536,
            "output": 12288
          }
        }
      }
    },
    "Ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://host.docker.internal:11434/v1",
        "timeout": 1800000,
        "chunkTimeout": 120000
      },
      "models": {
        "devstral:24b": {
          "name": "Devstral 24B"
        }
      }
    }
  },
  "mcp": {
    "rag-mcp": {
      "type": "remote",
      "url": "http://host.docker.internal:8765/mcp",
      "enabled": true,
      "oauth": false
    }
  },
  "lsp": {
    "clangd": {
      "disabled": true
    },
    "pyright": {
      "command": [
        "pyright"
      ]
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask"
    },
    "edit": "allow",
    "rag-mcp_*": "allow",
    "rag-mcp_delete_project_index": "ask",
    "read": "allow"
  }
}