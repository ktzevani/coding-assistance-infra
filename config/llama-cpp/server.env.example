# Routing-mode server configuration
LLAMA_CPP_HOST_PORT=8080
LLAMA_CPP_MODELS_PRESET=/config/models.ini
LLAMA_CPP_MODELS_MAX=1
LLAMA_CPP_FLASH_ATTN=on
LLAMA_CPP_CONT_BATCHING=true
LLAMA_CPP_MODELS_AUTOLOAD=true
LLAMA_CPP_METRICS=false

# Dedicated embedding GGUF server
LLAMA_CPP_EMBED_MODEL_PATH=/models/Qwen3-Embedding-0.6B-Q8_0.gguf
LLAMA_CPP_EMBED_MODEL_HF_REPO=Qwen/Qwen3-Embedding-0.6B-GGUF
LLAMA_CPP_EMBED_MODEL_HF_FILE=Qwen3-Embedding-0.6B-Q8_0.gguf
LLAMA_CPP_EMBED_HF_REPO=
LLAMA_CPP_EMBED_MODEL_ID=qwen3-embedding-0.6b-q8_0
LLAMA_CPP_EMBED_CTX_SIZE=8192
LLAMA_CPP_EMBED_N_GPU_LAYERS=-1
LLAMA_CPP_EMBED_THREADS=8
LLAMA_CPP_EMBED_BATCH_SIZE=2048
LLAMA_CPP_EMBED_UBATCH_SIZE=512
LLAMA_CPP_EMBED_PARALLEL=1
LLAMA_CPP_EMBED_POOLING=last
