# Project and storage
COMPOSE_PROJECT_NAME=coding-assistance-infra
DATA_ROOT=./data
MODEL_ROOT=./models

# GPU / backend profile
GPU_BACKEND=cpu
# NVIDIA device count: all or a positive integer
GPU_COUNT=all

# Ollama inference and embeddings
OLLAMA_IMAGE=ollama/ollama:latest
OLLAMA_ROCM_IMAGE=ollama/ollama:rocm
OLLAMA_HOST_PORT=11434
OLLAMA_KEEP_ALIVE=24h
OLLAMA_NUM_PARALLEL=1
OLLAMA_FLASH_ATTENTION=1
OLLAMA_CONTEXT_LENGTH=8192
FAST_MODEL_OLLAMA=devstral:24b
EMBED_MODEL_OLLAMA=qwen3-embedding:0.6b

# llama.cpp coding router
LLAMA_CPP_BASE_IMAGE=ghcr.io/ggml-org/llama.cpp:server
LLAMA_CPP_CUDA_BASE_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
LLAMA_CPP_HOST_PORT=8080
LLAMA_CPP_CONFIG_ROOT=./config/llama-cpp
LLAMA_CPP_MODELS_PRESET=/config/models.ini
LLAMA_CPP_MODELS_MAX=1
LLAMA_CPP_MODELS_AUTOLOAD=true
LLAMA_CPP_METRICS=false
# Model profile used by smoke tests
LLAMA_CPP_CHAT_MODEL=qwen3-coder-30b-64k
# Optional coding GGUF downloads
# e.g.
# LLAMA_CPP_MODEL_PATH_{n}=
# LLAMA_CPP_MODEL_HF_REPO_{n}=
# LLAMA_CPP_MODEL_HF_FILE_{n}=
LLAMA_CPP_MODEL_PATH_1=/models/Qwen3-Coder-30B-A3B-Instruct-UD-Q4_K_XL.gguf
LLAMA_CPP_MODEL_HF_REPO_1=unsloth/Qwen3-Coder-30B-A3B-Instruct-GGUF
LLAMA_CPP_MODEL_HF_FILE_1=Qwen3-Coder-30B-A3B-Instruct-UD-Q4_K_XL.gguf
LLAMA_CPP_MODEL_PATH_2=/models/Qwen3.6-35B-A3B-UD-Q3_K_S.gguf
LLAMA_CPP_MODEL_HF_REPO_2=unsloth/Qwen3.6-35B-A3B-GGUF
LLAMA_CPP_MODEL_HF_FILE_2=Qwen3.6-35B-A3B-UD-Q3_K_S.gguf

# Hugging Face token for private or gated GGUF downloads
HF_TOKEN=

# llama.cpp dedicated embedding server
LLAMA_CPP_EMBED_HOST_PORT=8081
LLAMA_CPP_EMBED_MODEL_PATH=/models/Qwen3-Embedding-0.6B-Q8_0.gguf
LLAMA_CPP_EMBED_MODEL_HF_REPO=Qwen/Qwen3-Embedding-0.6B-GGUF
LLAMA_CPP_EMBED_MODEL_HF_FILE=Qwen3-Embedding-0.6B-Q8_0.gguf
# Alternative to a local path: Qwen/Qwen3-Embedding-0.6B-GGUF:Q8_0
LLAMA_CPP_EMBED_HF_REPO=
LLAMA_CPP_EMBED_MODEL_ID=qwen3-embedding-0.6b-q8_0
LLAMA_CPP_EMBED_CTX_SIZE=8192
# CPU and NVIDIA use separate defaults so selecting a backend remains sufficient.
LLAMA_CPP_EMBED_N_GPU_LAYERS_CPU=0
LLAMA_CPP_EMBED_N_GPU_LAYERS_NVIDIA=-1
LLAMA_CPP_EMBED_THREADS=8
LLAMA_CPP_EMBED_BATCH_SIZE=2048
LLAMA_CPP_EMBED_UBATCH_SIZE=512
LLAMA_CPP_EMBED_PARALLEL=1
LLAMA_CPP_EMBED_POOLING=last

# RAG and Qdrant
QDRANT_IMAGE=qdrant/qdrant:latest
QDRANT_HOST_PORT=6333
RAG_MCP_HOST_PORT=8765
RAG_WORKSPACE_ROOT=./workspaces
EMBEDDING_BACKEND=ollama
EMBEDDING_BASE_URL=http://ollama:11434
EMBEDDING_MODEL=qwen3-embedding:0.6b
EMBEDDING_DOCUMENT_PREFIX=
EMBEDDING_QUERY_PREFIX=
QDRANT_COLLECTION=project_memory
RAG_TOP_K=8
RAG_MAX_CHUNK_TOKENS=600
# Approximate total token budget returned by search_project_memory
RAG_MAX_CONTEXT_TOKENS=4000
# Container path to YAML include/exclude rules keyed by collection name
RAG_COLLECTIONS_CONFIG=/config/rag/collections.example.yaml
