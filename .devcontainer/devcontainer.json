{
  "name": "Local AI Coding Facility",
  "dockerComposeFile": [
    "../docker-compose.yml",
    "../docker-compose.dev.yml"
  ],
  "service": "dev",
  "runServices": ["dev"],
  "workspaceFolder": "/opt/project",
  "shutdownAction": "none",
  "customizations": {
    "vscode": {
      "extensions": [
        "bierner.markdown-mermaid",
        "ms-azuretools.vscode-docker",
        "ms-python.python",
        "charliermarsh.ruff",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml"
      ]
    }
  },
  "remoteUser": "root"
}

